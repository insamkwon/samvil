{
  "name": "samvil",
  "description": "AI vibe-coding harness: one-line input, full web app output.",
  "version": "1.0.0",
  "author": {
    "name": "insam"
  },
  "license": "UNLICENSED",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/setup-mcp.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/guard-destructive.sh \"$TOOL_INPUT\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-seed-unchanged.sh \"$TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-build-result.sh \"$TOOL_INPUT\" \"$TOOL_EXIT_CODE\""
          }
        ]
      }
    ]
  }
}
