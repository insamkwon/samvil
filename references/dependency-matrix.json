{
  "_comment": "SAMVIL Dependency Matrix — Pinned versions for deterministic scaffold. Updated: 2026-04-11",
  "_update_policy": "Update when: 1) CI breaks on a pinned version 2) Security patch needed 3) Monthly review",

  "nextjs14": {
    "cli_command": "npx create-next-app@14.2.35",
    "framework": "next@14.2.35",
    "react": "react@18.3.1",
    "react_dom": "react-dom@18.3.1",
    "typescript": "typescript@5.7.3",
    "tailwindcss": "tailwindcss@3.4.19",
    "postcss": "postcss@8.5.3",
    "autoprefixer": "autoprefixer@10.4.21",
    "tailwindcss_animate": "tailwindcss-animate@1.0.7",
    "shadcn_cli": "shadcn@2.6.3",
    "clsx": "clsx@2.1.1",
    "tailwind_merge": "tailwind-merge@3.5.0",
    "eslint": "eslint@8.57.1",
    "eslint_config_next": "eslint-config-next@14.2.35",
    "shadcn_components": ["button", "card", "input", "dialog", "label", "select", "textarea"],
    "notes": "shadcn init generates Tailwind v4 CSS. Must overwrite with HSL v3 config after init."
  },

  "vite-react": {
    "cli_command": "npm create vite@5.4.21 -- --template react-ts",
    "framework": "vite@5.4.21",
    "react": "react@18.3.1",
    "react_dom": "react-dom@18.3.1",
    "typescript": "typescript@5.7.3",
    "tailwindcss_vite": "@tailwindcss/vite@4.2.2",
    "tailwindcss": "tailwindcss@4.1.4",
    "shadcn_cli": "shadcn@2.6.3",
    "clsx": "clsx@2.1.1",
    "tailwind_merge": "tailwind-merge@3.5.0",
    "shadcn_components": ["button", "card", "input", "dialog", "label", "select", "textarea"],
    "notes": "Vite uses Tailwind v4 natively. @tailwindcss/vite plugin required. shadcn supports v4 directly."
  },

  "astro": {
    "cli_command": "npm create astro@6.1.5 -- --template minimal --install --no-git --typescript strict",
    "framework": "astro@6.1.5",
    "react": "react@18.3.1",
    "react_dom": "react-dom@18.3.1",
    "typescript": "typescript@5.7.3",
    "astro_tailwind": "@astrojs/tailwind@6.0.2",
    "astro_react": "@astrojs/react@4.2.4",
    "clsx": "clsx@2.1.1",
    "tailwind_merge": "tailwind-merge@3.5.0",
    "shadcn_components": [],
    "notes": "Astro uses React islands. shadcn/ui manual setup required — copy component files from Next.js setup."
  },

  "common": {
    "supabase_js": "@supabase/supabase-js@2.49.4",
    "supabase_ssr": "@supabase/ssr@0.6.1",
    "playwright": "@playwright/test@1.52.0"
  }
