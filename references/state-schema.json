{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "samvil://state-schema/v1",
  "title": "SAMVIL State Schema",
  "description": "Runtime state for SAMVIL pipeline execution. Updated at each stage transition.",
  "type": "object",
  "required": ["seed_version", "current_stage"],
  "additionalProperties": true,
  "properties": {
    "seed_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Current seed version"
    },
    "current_stage": {
      "type": "string",
      "enum": ["interview", "seed", "scaffold", "build", "qa", "retro", "evolve", "complete"],
      "description": "Current pipeline stage"
    },
    "session_id": {
      "type": ["string", "null"],
      "description": "MCP session ID for event tracking"
    },
    "completed_features": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "List of completed feature names"
    },
    "in_progress": {
      "type": ["string", "null"],
      "default": null,
      "description": "Currently building feature name"
    },
    "failed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "feature": { "type": "string" },
          "stage": { "type": "string" },
          "error": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["feature", "stage", "error"]
      },
      "default": []
    },
    "build_retries": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "qa_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pass": { "type": "integer" },
          "fail": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "default": []
    },
    "retro_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "ai_answer_streak": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Consecutive AI auto-answered questions in interview. Resets when user answers directly (PATH 2). Triggers Rhythm Guard at 3. (v2.3.0+ scaffold, v2.4.0 full wiring)"
    },
    "interview_tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "rounds_focused": { "type": "integer", "minimum": 0 },
          "is_resolved": { "type": "boolean" }
        }
      },
      "default": [],
      "description": "Unresolved ambiguity tracks during interview. Breadth-Keeper uses for zoom-out reminders. (v2.3.0+ scaffold, v2.4.0 full wiring)"
    },
    "failed_acs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ac_id": { "type": "string" },
          "feature": { "type": "string" },
          "reason": { "type": "string" },
          "cycle": { "type": "integer" }
        }
      },
      "default": [],
      "description": "Accumulated failed ACs across cycles. Fed to Evolve Wonder as learning signal (P6 Fail-Fast Learn Later). (v2.3.0+ scaffold, v2.6.0 full wiring)"
    }
  }
}
