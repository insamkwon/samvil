{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "samvil://seed-schema/v3",
  "title": "SAMVIL Seed Schema",
  "description": "Immutable specification for SAMVIL project generation. v3.0.0 introduces AC Tree structure; root-level acceptance_criteria is optional when schema_version starts with \"3.\" — tree leaves inside features[] satisfy the \"at least 1 AC\" guarantee.",
  "type": "object",
  "required": ["name", "description", "solution_type", "tech_stack", "core_experience", "features", "constraints", "out_of_scope", "version"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+",
      "description": "Major version governs validation path (\"3.x\" → tree validation; missing or \"2.*\" → legacy root-AC path)."
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 100,
      "description": "kebab-case project name, must be valid npm package name"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "One-line project description"
    },
    "mode": {
      "type": "string",
      "enum": ["web", "mobile", "desktop"],
      "default": "web",
      "description": "DEPRECATED — use solution_type instead. Auto-migrated: mode:web → solution_type:web-app"
    },
    "solution_type": {
      "type": "string",
      "enum": ["web-app", "automation", "game", "mobile-app", "dashboard"],
      "default": "web-app",
      "description": "Solution type determines pipeline branching"
    },
    "implementation": {
      "type": "object",
      "description": "Implementation details (optional, auto-filled by seed stage)",
      "properties": {
        "type": {
          "type": "string",
          "description": "e.g., nextjs-webapp, python-automation, phaser-game, expo-mobile"
        },
        "runtime": {
          "type": "string",
          "enum": ["node", "python", "browser", "hybrid"],
          "description": "Primary runtime environment"
        },
        "entry_point": {
          "type": "string",
          "description": "e.g., app/page.tsx, src/main.py, src/game.ts"
        }
      },
      "additionalProperties": false
    },
    "tech_stack": {
      "type": "object",
      "required": ["framework"],
      "additionalProperties": false,
      "properties": {
        "framework": {
          "type": "string",
          "enum": ["nextjs", "vite-react", "astro", "phaser", "expo", "python-script", "node-script"],
          "description": "Target framework"
        },
        "ui": {
          "type": "string",
          "enum": ["tailwind", "css-modules", "styled-components"],
          "default": "tailwind",
          "description": "UI library (optional — automation/game may not need one)"
        },
        "state": {
          "type": "string",
          "enum": ["zustand", "useState", "jotai", "none"],
          "default": "useState",
          "description": "State management (optional — automation scripts may not need one)"
        },
        "router": {
          "type": "string",
          "enum": ["app-router", "pages-router", "react-router"],
          "default": "app-router",
          "description": "Router (optional — automation/game may not need one)"
        }
      }
    },
    "core_experience": {
      "description": "Core user experience — screen-based (web-app/dashboard) or flow-based (automation/game/mobile-app)",
      "oneOf": [
        {
          "type": "object",
          "title": "screen",
          "required": ["description", "primary_screen", "key_interactions"],
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "minLength": 20,
              "description": "What user does in first 30 seconds"
            },
            "primary_screen": {
              "type": "string",
              "pattern": "^[A-Z][a-zA-Z0-9]*$",
              "description": "PascalCase component name for primary screen"
            },
            "key_interactions": {
              "type": "array",
              "items": { "type": "string", "minLength": 3 },
              "minItems": 1,
              "maxItems": 10,
              "description": "Verb-noun format interaction descriptions"
            }
          }
        },
        {
          "type": "object",
          "title": "core_flow",
          "required": ["description", "input", "output", "trigger"],
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "minLength": 20,
              "description": "What this automation/game/mobile flow accomplishes"
            },
            "input": {
              "type": "string",
              "description": "What goes in — data source, trigger payload, user action"
            },
            "output": {
              "type": "string",
              "description": "What comes out — result, side effect, transformed data"
            },
            "trigger": {
              "type": "string",
              "description": "How it starts — manual, cron schedule, webhook, user event"
            }
          }
        }
      ]
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "priority"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "kebab-case feature name"
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "independent": {
            "type": "boolean",
            "default": true
          },
          "depends_on": {
            "type": ["string", "null"],
            "default": null,
            "description": "Must reference an existing feature name if independent=false"
          },
          "description": {
            "type": "string",
            "minLength": 5,
            "description": "Human-readable feature description"
          }
        }
      },
      "minItems": 1
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 10 },
          {
            "type": "object",
            "required": ["criterion"],
            "properties": {
              "criterion": { "type": "string", "minLength": 10, "description": "Testable statement that defines done" },
              "vague_words": { "type": "array", "items": { "type": "string" }, "description": "Words flagged as ambiguous during interview" },
              "rewrite_hint": { "type": "string", "description": "Suggested rewrite to remove ambiguity" }
            }
          },
          {
            "type": "object",
            "description": "AC Tree node (v2.5.0+). See references/ac-tree-guide.md. Backward-compat: strings/criterion objects still work.",
            "required": ["description"],
            "properties": {
              "id": { "type": "string", "description": "Hierarchical ID (AC-1.2.1 style). Auto-assigned if omitted." },
              "description": { "type": "string", "minLength": 5 },
              "children": {
                "type": "array",
                "items": { "$ref": "#/properties/acceptance_criteria/items" },
                "description": "Sub-ACs. Max depth 3."
              },
              "status": {
                "type": "string",
                "enum": ["pending", "in_progress", "pass", "fail", "blocked", "skipped"],
                "default": "pending"
              },
              "evidence": {
                "type": "array",
                "items": { "type": "string", "description": "file:line reference" }
              }
            }
          }
        ]
      },
      "minItems": 1,
      "description": "Testable statements that define done. v2.5.0+ supports AC Tree (recursive) — flat strings and tree nodes can coexist."
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Technical or business constraints. Empty = red flag."
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Explicitly excluded features. Empty = scope creep risk."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Schema version, increments on evolve"
    },
    "customer_lifecycle": {
      "type": "object",
      "description": "Customer Lifecycle Journey (v3.1.0, v3-023). 8 stages of user experience over time. All fields optional — 사용자가 모를 수 있음. 'TBD — research needed' 표기는 PATH 4 Research에 위임하는 신호다. standard tier 이상에서 인터뷰가 수집.",
      "additionalProperties": false,
      "properties": {
        "discovery": {
          "type": "string",
          "description": "How users learn the product exists (search/referral/ads/offline)"
        },
        "first_open": {
          "type": "string",
          "description": "What the user sees in the first 5 seconds + empty state"
        },
        "onboarding": {
          "type": "string",
          "description": "Signup strategy, tutorial, sample data"
        },
        "activation": {
          "type": "string",
          "description": "The Aha moment — one sentence describing when the user feels value"
        },
        "retention": {
          "type": "string",
          "description": "Reasons to come back daily/weekly, push/email policy"
        },
        "completion": {
          "type": "string",
          "description": "What happens when the user finishes (level clear, tasks done, content consumed)"
        },
        "re_engagement": {
          "type": "string",
          "description": "Win-back strategy for users who left for a month+"
        },
        "churn": {
          "type": "string",
          "description": "Churn signal detection and exit survey strategy"
        },
        "data_retention": {
          "type": "string",
          "description": "Data retention policy after churn (immediate delete / 30-day grace / export)"
        }
      }
    },
    "non_functional": {
      "type": "object",
      "description": "Non-functional requirements (v3.1.0, v3-022). Performance, accessibility, security, etc. Collected by Interview Phase 2.6 in thorough+ tier.",
      "additionalProperties": false,
      "properties": {
        "performance_target": {
          "type": "string",
          "description": "e.g., 'LCP < 2.5s', 'first paint < 1s'"
        },
        "accessibility_target": {
          "type": "string",
          "description": "e.g., 'WCAG AA', 'keyboard-only operable', 'none'"
        },
        "security_sensitivity": {
          "type": "string",
          "enum": ["none", "pii", "payment", "enterprise-secret", "mixed"],
          "description": "Most sensitive data category handled"
        },
        "data_retention_days": {
          "type": ["integer", "null"],
          "description": "Days before user data auto-deletes after churn. null = indefinite."
        },
        "offline_support": {
          "type": "string",
          "enum": ["none", "cached-read", "full-offline"],
          "description": "Offline behavior expectation"
        },
        "i18n_languages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Supported languages (BCP 47 tags). Empty = Korean-only."
        },
        "error_ux": {
          "type": "string",
          "enum": ["toast", "banner", "full-page", "inline", "mixed"],
          "description": "Dominant error presentation style"
        }
      }
    },
    "inversion": {
      "type": "object",
      "description": "Inversion phase outputs (v3.1.0, v3-022). Failure modes, anti-requirements. Collected by Interview Phase 2.7.",
      "additionalProperties": false,
      "properties": {
        "failure_paths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Top reasons this product could be abandoned within 6 months"
        },
        "anti_requirements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Things users MUST be prevented from doing (e.g., duplicate signup, privilege escalation)"
        },
        "abuse_vectors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known abuse/attack patterns to defend against"
        }
      }
    },
    "stakeholders": {
      "type": "object",
      "description": "Stakeholder & JTBD outputs (v3.1.0, v3-022). full tier only. Collected by Interview Phase 2.8.",
      "additionalProperties": false,
      "properties": {
        "primary_user_jtbd": {
          "type": "string",
          "description": "When <situation>, I want to <motivation>, so I can <outcome>."
        },
        "secondary_users": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Non-primary roles (admin/reviewer/observer)"
        },
        "decision_maker": {
          "type": "string",
          "description": "Who decides to adopt — user/manager/IT/self"
        },
        "payer": {
          "type": "string",
          "description": "Who pays — user/company/free"
        },
        "motivation_vs_alternatives": {
          "type": "string",
          "description": "Why this product over existing alternatives (Excel/Notion/paper)"
        }
      }
    },
    "game_config": {
      "type": "object",
      "description": "Mobile/web game technical config (v3.1.0, v3-014). Populated by game-interviewer for solution_type=game. Scaffold reads these to generate correct Phaser config instead of defaulting to 800x600.",
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 240,
          "maximum": 7680,
          "description": "Base canvas width in CSS pixels"
        },
        "height": {
          "type": "integer",
          "minimum": 240,
          "maximum": 4320,
          "description": "Base canvas height in CSS pixels"
        },
        "orientation": {
          "type": "string",
          "enum": ["portrait", "landscape", "both"],
          "description": "Screen orientation policy"
        },
        "input": {
          "type": "array",
          "items": { "type": "string", "enum": ["keyboard", "mouse", "touch", "multitouch", "gamepad"] },
          "description": "Supported input modalities"
        },
        "supported_devices": {
          "type": "array",
          "items": { "type": "string", "enum": ["ios", "android", "tablet", "desktop"] },
          "description": "Target devices"
        },
        "offline_play": {
          "type": "string",
          "enum": ["required", "optional", "never"],
          "description": "Offline play requirement"
        },
        "asset_budget_mb": {
          "type": ["number", "null"],
          "description": "Initial asset download budget in MB. null = unlimited"
        }
      }
    },
    "game_architecture": {
      "type": "object",
      "description": "Game lifecycle + persistence architecture (v3.1.0, v3-013). Populated by game-interviewer for solution_type=game.",
      "additionalProperties": false,
      "properties": {
        "solo_multi": {
          "type": "string",
          "enum": ["solo", "local-2p", "online-multi"],
          "description": "Player count architecture"
        },
        "login_strategy": {
          "type": "string",
          "enum": ["anonymous", "guest", "email", "oauth", "none"],
          "description": "Authentication approach"
        },
        "data_storage": {
          "type": "string",
          "enum": ["localStorage", "cloud-sync", "server-required"],
          "description": "Progress persistence location"
        },
        "save_policy": {
          "type": "string",
          "enum": ["auto-save", "manual", "checkpoint"],
          "description": "When saves happen"
        },
        "leaderboard": {
          "type": "string",
          "enum": ["global", "friends", "none"],
          "description": "Ranking system"
        },
        "iap_policy": {
          "type": "string",
          "enum": ["none", "one-time", "consumables", "subscription"],
          "description": "Monetization"
        },
        "matchmaking_policy": {
          "type": "string",
          "enum": ["invite", "random", "skill-based", "not-applicable"],
          "description": "Multiplayer matchmaking (only if solo_multi=online-multi)"
        }
      }
    },
    "art_design": {
      "type": "object",
      "description": "Game art direction + audio (v3.1.0, v3-015). Populated by game-interviewer + referenced by game-art-architect in samvil-design.",
      "additionalProperties": false,
      "properties": {
        "character_art": {
          "type": "string",
          "enum": ["pixel-8bit", "pixel-16bit", "cartoon", "symbolic", "3d-render"],
          "description": "Character visual style"
        },
        "ui_style_tone": {
          "type": "string",
          "enum": ["minimal-clean", "fantasy", "sci-fi", "cute-pastel", "retro"],
          "description": "UI aesthetic"
        },
        "animation_level": {
          "type": "string",
          "enum": ["static", "tween-only", "sprite-sheet", "particle-included"],
          "description": "Animation complexity"
        },
        "sound_policy": {
          "type": "string",
          "enum": ["full-sound", "sfx-only", "muted-default"],
          "description": "BGM/SFX policy"
        },
        "hud_layout": {
          "type": "array",
          "items": { "type": "string" },
          "description": "HUD elements (score/health/timer/minimap/inventory)"
        },
        "character_count": {
          "type": "string",
          "enum": ["1", "2-5", "6+", "customizable"],
          "description": "Number of unique characters"
        }
      }
    },
    "external_api_config": {
      "type": "object",
      "description": "External API configuration for automation projects (v3.1.0, v3-025). Lists model IDs and provider configs that must be externalized to .env.example so deprecated models can be swapped without rebuild.",
      "additionalProperties": false,
      "properties": {
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "env_var", "default_model"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Provider name (e.g., 'gemini', 'openai', 'anthropic')"
              },
              "env_var": {
                "type": "string",
                "description": "Env variable name (e.g., 'GEMINI_MODEL')"
              },
              "default_model": {
                "type": "string",
                "description": "Default model ID. Must be stored in .env.example, never hardcoded in source."
              },
              "fallback_model": {
                "type": ["string", "null"],
                "description": "Optional fallback when default is deprecated"
              }
            }
          }
        }
      }
    }
  }
}
