{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "samvil://seed-schema/v2",
  "title": "SAMVIL Seed Schema",
  "description": "Immutable specification for SAMVIL project generation. Version starts at 1, increments on evolve.",
  "type": "object",
  "required": ["name", "description", "solution_type", "tech_stack", "core_experience", "features", "acceptance_criteria", "constraints", "out_of_scope", "version"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 100,
      "description": "kebab-case project name, must be valid npm package name"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "One-line project description"
    },
    "mode": {
      "type": "string",
      "enum": ["web", "mobile", "desktop"],
      "default": "web",
      "description": "DEPRECATED — use solution_type instead. Auto-migrated: mode:web → solution_type:web-app"
    },
    "solution_type": {
      "type": "string",
      "enum": ["web-app", "automation", "game", "mobile-app", "dashboard"],
      "default": "web-app",
      "description": "Solution type determines pipeline branching"
    },
    "implementation": {
      "type": "object",
      "description": "Implementation details (optional, auto-filled by seed stage)",
      "properties": {
        "type": {
          "type": "string",
          "description": "e.g., nextjs-webapp, python-automation, phaser-game, expo-mobile"
        },
        "runtime": {
          "type": "string",
          "enum": ["node", "python", "browser", "hybrid"],
          "description": "Primary runtime environment"
        },
        "entry_point": {
          "type": "string",
          "description": "e.g., app/page.tsx, src/main.py, src/game.ts"
        }
      },
      "additionalProperties": false
    },
    "tech_stack": {
      "type": "object",
      "required": ["framework"],
      "additionalProperties": false,
      "properties": {
        "framework": {
          "type": "string",
          "enum": ["nextjs", "vite-react", "astro", "phaser", "expo", "python-script", "node-script"],
          "description": "Target framework"
        },
        "ui": {
          "type": "string",
          "enum": ["tailwind", "css-modules", "styled-components"],
          "default": "tailwind",
          "description": "UI library (optional — automation/game may not need one)"
        },
        "state": {
          "type": "string",
          "enum": ["zustand", "useState", "jotai", "none"],
          "default": "useState",
          "description": "State management (optional — automation scripts may not need one)"
        },
        "router": {
          "type": "string",
          "enum": ["app-router", "pages-router", "react-router"],
          "default": "app-router",
          "description": "Router (optional — automation/game may not need one)"
        }
      }
    },
    "core_experience": {
      "description": "Core user experience — screen-based (web-app/dashboard) or flow-based (automation/game/mobile-app)",
      "oneOf": [
        {
          "type": "object",
          "title": "screen",
          "required": ["description", "primary_screen", "key_interactions"],
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "minLength": 20,
              "description": "What user does in first 30 seconds"
            },
            "primary_screen": {
              "type": "string",
              "pattern": "^[A-Z][a-zA-Z0-9]*$",
              "description": "PascalCase component name for primary screen"
            },
            "key_interactions": {
              "type": "array",
              "items": { "type": "string", "minLength": 3 },
              "minItems": 1,
              "maxItems": 10,
              "description": "Verb-noun format interaction descriptions"
            }
          }
        },
        {
          "type": "object",
          "title": "core_flow",
          "required": ["description", "input", "output", "trigger"],
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "minLength": 20,
              "description": "What this automation/game/mobile flow accomplishes"
            },
            "input": {
              "type": "string",
              "description": "What goes in — data source, trigger payload, user action"
            },
            "output": {
              "type": "string",
              "description": "What comes out — result, side effect, transformed data"
            },
            "trigger": {
              "type": "string",
              "description": "How it starts — manual, cron schedule, webhook, user event"
            }
          }
        }
      ]
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "priority"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "kebab-case feature name"
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "independent": {
            "type": "boolean",
            "default": true
          },
          "depends_on": {
            "type": ["string", "null"],
            "default": null,
            "description": "Must reference an existing feature name if independent=false"
          },
          "description": {
            "type": "string",
            "minLength": 5,
            "description": "Human-readable feature description"
          }
        }
      },
      "minItems": 1
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 10 },
          {
            "type": "object",
            "required": ["criterion"],
            "properties": {
              "criterion": { "type": "string", "minLength": 10, "description": "Testable statement that defines done" },
              "vague_words": { "type": "array", "items": { "type": "string" }, "description": "Words flagged as ambiguous during interview" },
              "rewrite_hint": { "type": "string", "description": "Suggested rewrite to remove ambiguity" }
            }
          },
          {
            "type": "object",
            "description": "AC Tree node (v2.5.0+). See references/ac-tree-guide.md. Backward-compat: strings/criterion objects still work.",
            "required": ["description"],
            "properties": {
              "id": { "type": "string", "description": "Hierarchical ID (AC-1.2.1 style). Auto-assigned if omitted." },
              "description": { "type": "string", "minLength": 5 },
              "children": {
                "type": "array",
                "items": { "$ref": "#/properties/acceptance_criteria/items" },
                "description": "Sub-ACs. Max depth 3."
              },
              "status": {
                "type": "string",
                "enum": ["pending", "in_progress", "pass", "fail", "blocked", "skipped"],
                "default": "pending"
              },
              "evidence": {
                "type": "array",
                "items": { "type": "string", "description": "file:line reference" }
              }
            }
          }
        ]
      },
      "minItems": 1,
      "description": "Testable statements that define done. v2.5.0+ supports AC Tree (recursive) — flat strings and tree nodes can coexist."
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Technical or business constraints. Empty = red flag."
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Explicitly excluded features. Empty = scope creep risk."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Schema version, increments on evolve"
    }
  }
}
